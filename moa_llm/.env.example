# Copy this file to ".env" (same folder) and fill in your real key.
# .env is gitignored so the secret never lands in version control.

# Required: API key for the ai.qestit.com gateway.
QESTIT_AI_API_KEY=your-key-here

# Optional overrides:
# Model id (internal gateway slug, NOT an OpenAI name). Default: mdl_azure_gpt54 (GPT 5.4).
# Other good options: mdl_azure_gpt54_mini, mdl_aws_claude_opus_48, mdl_azure_gpt52
# MOA_LLM_MODEL=mdl_azure_gpt54

# Base URL of the OpenAI-compatible gateway. Default shown below.
# QESTIT_AI_BASE_URL=https://ai.qestit.com/openai/v1
